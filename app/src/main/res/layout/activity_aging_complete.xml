<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFF8FBFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="숙성 완료 일기"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tv_emotion_combo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/tv_aging_complete_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textColor="@color/text_secondary" />

    <EditText
        android:id="@+id/et_aged_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp"
        android:gravity="top|start"
        android:hint="7일간 숙성된 감정에 대한 생각을 적어보세요"
        android:inputType="textMultiLine"
        android:minLines="5"
        android:background="@drawable/bg_edit_text"
        android:padding="12dp" />

    <ProgressBar
        android:id="@+id/progress_submit"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_submit_aged_diary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="완료"
        android:backgroundTint="#A6E4A6"
        android:textColor="#000000" />

</LinearLayout>
