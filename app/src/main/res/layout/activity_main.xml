<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

        <!-- 배경: 캐릭터 이미지 전체 화면 -->
        <ImageView
            android:id="@+id/background_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/home_screen"
            android:contentDescription="@string/app_name" />

        <!-- 말풍선 오버레이 (캐릭터 머리 위 영역) -->
        <TextView
            android:id="@+id/tvSpeechBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="164dp"
            android:layout_marginTop="102dp"
            android:layout_marginEnd="12dp"
            android:gravity="center"
            android:textColor="#333333"
            android:textSize="13sp"
            tools:text="오늘 마음은 어때요?" />

        <!-- 4개 버튼 2×2 그리드 (btnSelectionBox 위에 위치) -->
        <GridLayout
            android:id="@+id/mainGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/selectionBoxContainer"
            android:layout_marginBottom="8dp"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:padding="8dp">

            <Button
                android:id="@+id/btnTodayJelly"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="#A6E4A6"
                android:text="오늘의\n마음젤리"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnJellyDrawer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="#FFE0A4"
                android:text="젤리 서랍"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnAgingRoom"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="#D4E4FF"
                android:text="에이징룸"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp" />

            <Button
                android:id="@+id/btnJellyMuseum"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="#FFC5C5"
                android:text="젤리 뮤지엄"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp" />

        </GridLayout>

        <!-- 우측 상단 설정 진입 (배경 위 오버레이) -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/main_settings_desc"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_settings"
            app:tint="#444444" />

        <!-- 젤리셀렉션박스 — 다른 버튼과 동일 크기, 중앙 정렬 -->
        <LinearLayout
            android:id="@+id/selectionBoxContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="0.5" />

            <Button
                android:id="@+id/btnSelectionBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#A3D7FF"
                android:text="젤리 셀렉션 박스"
                android:textColor="#000000"
                android:textSize="14sp"
                android:padding="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="0.5" />

        </LinearLayout>

</RelativeLayout>
